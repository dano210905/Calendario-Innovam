@page "/admin/usuarios"
@rendermode InteractiveServer
@inject Front_innovam.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="container-fluid min-vh-100 px-4 pt-5" style="background: linear-gradient(135deg, #021e49 0%, #1a3a6e 50%, #2c4a8a 100%); 
            display: flex; 
            flex-direction: column; 
            margin-left: -2rem !important; 
            margin-right: -2rem !important; 
            margin-top: -2rem !important;
            padding-top: 3.5rem !important;
            width: calc(100% + 4rem) !important; 
            min-width: calc(100% + 4rem) !important;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-primary mb-0">
                <i class="bi bi-person-gear"></i> Gestión de Usuarios
            </h3>
            <p class="text-muted mt-2">Visualiza y elimina cuentas de usuario del sistema</p>

            <div class="admin-shortcut-container mb-4">
                <a href="/rol-usuario" class="admin-shortcut-card">
                    <div class="shortcut-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="shortcut-content">
                        <span class="shortcut-title">Administrar roles</span>
                        <span class="shortcut-desc">Cambiar el rol y ver datos personales</span>
                    </div>
                    <div class="shortcut-arrow">
                        <i class="bi bi-chevron-right"></i>
                    </div>
                </a>
            </div>

        </div>
        <div class="ms-auto">
            <span class="badge bg-primary rounded-pill px-3 py-2">
                Total: @usuarios.Count
            </span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show shadow-sm">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">

                <div class="d-flex align-items-center position-relative flex-grow-1" style="max-width: 450px;">
                    <i class="bi bi-search position-absolute text-muted" style="left: 15px; z-index: 5;"></i>
                    <input class="form-control rounded-pill" type="text" placeholder="Buscar por nombre o correo..."
                        style="padding-left: 40px; height: 42px; background-color: #f8fafc; border-color: #cbd5e1;"
                        @bind="textoBusqueda" @bind:event="oninput" @onkeyup="FiltrarUsuarios" />
                </div>

                <div class="d-flex align-items-center">
                    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6 shadow-sm">
                        Total: @(usuariosVisibles?.Count ?? 0)
                    </span>
                </div>

            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Correo Electrónico</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in usuariosVisibles)
                            {
                                <tr>
                                    <td class="align-middle fw-bold">@user["Nombre"]</td>
                                    <td class="align-middle">@user["email"]</td>
                                    <td class="text-center align-middle">
                                        <button class="btn btn-danger btn-sm" @onclick="() => PrepararEliminacion(user)">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (mostrarConfirmacion)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i> Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                        @onclick="() => mostrarConfirmacion = false"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <i class="bi bi-person-x text-danger" style="font-size: 4rem;"></i>
                    <p class="fs-5 mt-3">¿Estás seguro de que deseas eliminar a este usuario?</p>
                    <p class="text-muted small">
                        <strong>Nombre:</strong> @usuarioParaEliminar?["Nombre"]<br />
                        <strong>Email:</strong> @usuarioParaEliminar?["email"]
                    </p>
                    <div class="alert alert-warning py-2 small">
                        <i class="bi bi-info-circle"></i> Esta acción también eliminará sus roles asignados.
                    </div>
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4">
                    <button class="btn btn-secondary px-4" @onclick="() => mostrarConfirmacion = false">Cancelar</button>
                    <button class="btn btn-danger px-4" @onclick="ConfirmarBorradoReal">
                        <i class="bi bi-trash-fill"></i> Eliminar Definitivamente
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /*variables*/
    :root {
        --navy: #021e49;
        --navy-mid: #1a3a6e;
        --accent: #667eea;
        --accent-2: #0021db;
        --radius: 12px;
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* fondo*/
    .container {
        background: linear-gradient(135deg, #021e49 0%, #1a3a6e 50%, #2c4a8a 100%);
        min-height: 100vh;
        max-width: 100% !important;
        padding: 32px 24px !important;
        margin: 0 !important;
    }

    /*Titulo*/
    .text-primary {
        color: #ffffff !important;
    }

    .text-muted {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    /* botones*/
    .btn-primary,
    .btn-success {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%) !important;
        border: none !important;
        border-radius: var(--radius) !important;
        font-weight: 600 !important;
        transition: var(--transition) !important;
    }

    .btn-primary:hover,
    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(2, 30, 73, 0.35) !important;
    }

    .btn-outline-primary {
        border-color: var(--accent) !important;
        color: var(--accent) !important;
        border-radius: var(--radius) !important;
        font-weight: 600 !important;
        transition: var(--transition) !important;
    }

    .btn-outline-primary:hover {
        background: var(--accent) !important;
        color: white !important;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e2e8f0 !important;
        border: none !important;
        color: #475569 !important;
        border-radius: var(--radius) !important;
        font-weight: 600 !important;
    }

    .btn-warning {
        background: #fef3c7 !important;
        border: 1px solid #fcd34d !important;
        color: #92400e !important;
        border-radius: var(--radius) !important;
        font-weight: 600 !important;
        transition: var(--transition) !important;
    }

    .btn-warning:hover {
        background: #fde68a !important;
        transform: translateY(-1px);
    }

    .btn-danger {
        background: #fee2e2 !important;
        border: 1px solid #ff1818 !important;
        color: #361b99 !important;
        border-radius: var(--radius) !important;
        font-weight: 600 !important;
        transition: var(--transition) !important;
    }

    .btn-danger:hover {
        background: #fecaca !important;
        transform: translateY(-1px);
    }

    /*hector me la chupa en reversa(tabla)*/
    .card {
        border-radius: 20px !important;
        overflow: hidden !important;
        border: none !important;
        box-shadow: 0 20px 50px rgba(2, 30, 73, 0.18) !important;
        animation: fadeUp 0.4s ease-out;
    }

    .card-header.bg-gradient-primary {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%) !important;
        position: relative;
        padding: 20px 24px !important;
    }

    .card-header.bg-gradient-primary::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }

    .card-header h4 {
        font-weight: 700;
        font-size: 17px;
    }


    .table-dark {
        background: linear-gradient(135deg, var(--navy), var(--navy-mid)) !important;
    }

    .table-dark th {
        font-size: 13px !important;
        font-weight: 600 !important;
        letter-spacing: 0.5px !important;
        text-transform: uppercase !important;
        padding: 14px 20px !important;
        border: none !important;
    }

    .table tbody td {
        padding: 14px 20px !important;
        vertical-align: middle !important;
        border-color: #f1f5f9 !important;
    }

    .table-hover tbody tr:hover {
        background-color: #f8fafc !important;
        transition: var(--transition) !important;
    }


    .badge.bg-primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-2)) !important;
        border-radius: 999px !important;
        padding: 6px 14px !important;
        font-size: 13px !important;
    }

    .badge.bg-info {
        background: #eff6ff !important;
        color: #1d4ed8 !important;
        border: 1px solid #bfdbfe !important;
        border-radius: 999px !important;
        padding: 5px 12px !important;
        font-size: 13px !important;
        font-weight: 500 !important;
    }

    .form-control,
    .form-select {
        border: 2px solid #e2e8f0 !important;
        border-radius: var(--radius) !important;
        padding: 10px 14px !important;
        font-size: 14px !important;
        transition: var(--transition) !important;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--navy) !important;
        box-shadow: 0 0 0 3px rgba(2, 30, 73, 0.08) !important;
    }

    .form-label.fw-bold {
        color: #475569 !important;
        font-size: 13px !important;
    }

    .alert-success {
        background: #ecfdf5 !important;
        border-left: 4px solid #10b981 !important;
        border-radius: var(--radius) !important;
        color: #065f46 !important;
        border-top: none !important;
        border-right: none !important;
        border-bottom: none !important;
    }

    .alert-danger {
        background: #fef2f2 !important;
        border-left: 4px solid #dc2626 !important;
        border-radius: var(--radius) !important;
        color: #991b1b !important;
        border-top: none !important;
        border-right: none !important;
        border-bottom: none !important;
    }

    .alert-warning {
        background: rgba(255, 255, 255, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        border-radius: var(--radius) !important;
        color: rgba(255, 255, 255, 0.85) !important;
    }

    .alert-info {
        background: #eff6ff !important;
        border-left: 4px solid #3b82f6 !important;
        border-radius: var(--radius) !important;
        color: #1e40af !important;
        border-top: none !important;
        border-right: none !important;
        border-bottom: none !important;
    }


    .modal-backdrop {
        background-color: rgba(2, 30, 73, 0.55) !important;
        backdrop-filter: blur(4px) !important;
    }

    .modal-content {
        border-radius: 20px !important;
        border: none !important;
        overflow: hidden !important;
    }

    .modal-header.bg-gradient-primary {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%) !important;
        position: relative;
    }

    .modal-header.bg-gradient-primary::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }

    .modal-footer {
        background: #f8fafc !important;
        border-top: 1px solid #e2e8f0 !important;
    }

    .btn-close-white {
        filter: brightness(10);
    }

    .spinner-border.text-primary {
        border-color: rgba(255, 255, 255, 0.3) !important;
        border-top-color: white !important;
    }

    /* ── ANIMACIÓN ── */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 640px) {
        .container {
            padding: 16px 12px !important;
        }

        .card-header h4 {
            font-size: 15px;
        }
    }
</style>

@code {
    private List<Dictionary<string, object?>> usuarios = new();

    private List<Dictionary<string, object?>> usuariosVisibles = new();
    private string textoBusqueda = "";
    private bool cargando = true;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Variables para el Modal de advertencia
    private bool mostrarConfirmacion = false;
    private Dictionary<string, object?>? usuarioParaEliminar;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarios();
    }

    private async Task CargarUsuarios()
    {
        cargando = true;


        usuarios = await Api.ListarAsync("usuario");


        FiltrarUsuarios();

        cargando = false;
    }

    private void FiltrarUsuarios()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda))
        {
            usuariosVisibles = usuarios;
        }
        else
        {
            usuariosVisibles = usuarios.Where(u =>

            (u.ContainsKey("nombre") && u["nombre"]?.ToString()?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ==
            true) ||
            (u.ContainsKey("correo_electronico") && u["correo_electronico"]?.ToString()?.Contains(textoBusqueda,
            StringComparison.OrdinalIgnoreCase) == true) ||
            (u.ContainsKey("email") && u["email"]?.ToString()?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) == true)
            ).ToList();
        }
    }

    // Primer paso: Abrir la advertencia
    private void PrepararEliminacion(Dictionary<string, object?> user)
    {
        usuarioParaEliminar = user;
        mostrarConfirmacion = true;
    }

    // Segundo paso: Ejecutar la acción real
    private async Task ConfirmarBorradoReal()
    {
        if (usuarioParaEliminar == null) return;

        string email = usuarioParaEliminar["email"]?.ToString() ?? "";
        mostrarConfirmacion = false; // Cerramos el modal antes de procesar

        // 1. Borrar relación en rol_usuario (fkemail)
        var resRol = await Api.EliminarAsync("rol_usuario", "fkemail", email);

        if (resRol.exito)
        {
            // 2. Borrar el usuario
            var resUser = await Api.EliminarAsync("usuario", "email", email);
            exito = resUser.exito;
            mensaje = exito ? "Usuario eliminado con éxito" : resUser.mensaje;
        }
        else
        {
            exito = false;
            mensaje = "Error al limpiar roles: " + resRol.mensaje;
        }

        if (exito) await CargarUsuarios();
    }
}